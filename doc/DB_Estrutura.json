    },
    "filiais": {
      "columns": ["id", "nome", "endereco", "bairro", "telefone", "coordenadas", "imagem", "principal"]
    },
    "mensagens": {
      "columns": ["id", "nome", "email", "telefone", "assunto", "mensagem", "data_envio", "respondida"]
    },
    "produtos": {
      "columns": ["id", "nome", "descricao", "composicao", "preco", "estoque_atual", "categoria_id", "imagem", "data_validade", "em_destaque", "disponivel"]
    },
    "reservas": {
